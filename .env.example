# Sanity
SANITY_PROJECT_ID=your_project_id
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01
SANITY_TOKEN=your_read_token

# Optional: Mapbox (for MapEmbed component)
PUBLIC_MAPBOX_TOKEN=your_mapbox_token

# Optional: Form endpoint (Formspree, Netlify Forms, etc.)
PUBLIC_FORM_ENDPOINT=https://formspree.io/f/your_form_id
