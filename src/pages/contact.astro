---
import Base from "@/layouts/Base.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import ContactForm from "@/components/ContactForm";
import { sanityClient } from "@/lib/sanity";
import { siteSettingsQuery } from "@/lib/queries";

const settings = await sanityClient.fetch(siteSettingsQuery);
---

<Base title="Contact Us" description="Get in touch with our team. We're here to help with your property search.">
  <div class="container py-8 md:py-12">
    <Breadcrumbs
      items={[
        { label: "Home", href: "/" },
        { label: "Contact" },
      ]}
    />

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
      <div>
        <h1 class="text-3xl md:text-4xl font-bold mb-4">Get in Touch</h1>
        <p class="text-gray-500 mb-8">
          Whether you're looking to buy, sell, rent, or let — our team is ready to help.
        </p>

        <div class="space-y-6 mb-10">
          {settings?.phone && (
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background: var(--color-brand); opacity: 0.1">
                <svg class="w-5 h-5" style="color: var(--color-brand)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-sm">Phone</p>
                <a href={`tel:${settings.phone}`} class="text-gray-600 hover:underline">{settings.phone}</a>
              </div>
            </div>
          )}

          {settings?.email && (
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background: var(--color-brand); opacity: 0.1">
                <svg class="w-5 h-5" style="color: var(--color-brand)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-sm">Email</p>
                <a href={`mailto:${settings.email}`} class="text-gray-600 hover:underline">{settings.email}</a>
              </div>
            </div>
          )}
        </div>
      </div>

      <div class="bg-white rounded-xl border border-gray-200 p-6 md:p-8 shadow-sm">
        <h2 class="text-xl font-bold mb-6">Send Us a Message</h2>
        <ContactForm client:visible />
      </div>
    </div>
  </div>
</Base>
