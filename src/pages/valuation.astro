---
import Base from "@/layouts/Base.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import ContactForm from "@/components/ContactForm";
---

<Base title="Book a Free Valuation" description="Get a free, no-obligation property valuation from our local experts.">
  <div class="container py-8 md:py-12">
    <Breadcrumbs
      items={[
        { label: "Home", href: "/" },
        { label: "Free Valuation" },
      ]}
    />

    <div class="max-w-3xl mx-auto text-center mb-12">
      <h1 class="text-3xl md:text-5xl font-bold mb-4">
        What's Your Property Worth?
      </h1>
      <p class="text-gray-500 text-lg">
        Book a free, no-obligation valuation. Our local experts will visit your property and give you an honest, market-led appraisal.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-12 max-w-5xl mx-auto">
      <!-- Benefits -->
      <div>
        <h2 class="text-xl font-bold mb-6">Why Choose Us?</h2>
        <div class="space-y-5">
          {[
            { title: "Local Market Expertise", desc: "We know your area inside out — from pricing trends to buyer demand." },
            { title: "No Obligation", desc: "Our valuations are completely free. There's no pressure to list with us." },
            { title: "Accurate & Honest", desc: "We give realistic figures based on comparable sales, not inflated promises." },
            { title: "Quick Turnaround", desc: "Book today, get your valuation within 48 hours." },
          ].map((item) => (
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 bg-green-100">
                <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-sm">{item.title}</p>
                <p class="text-sm text-gray-500 mt-0.5">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Form -->
      <div class="bg-white rounded-xl border border-gray-200 p-6 md:p-8 shadow-sm">
        <h2 class="text-xl font-bold mb-6">Request Your Free Valuation</h2>
        <ContactForm client:visible />
      </div>
    </div>
  </div>
</Base>
