---
import Base from "@/layouts/Base.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import PropertyFilter from "@/components/PropertyFilter";
import { sanityClient } from "@/lib/sanity";
import { allPropertiesQuery, allTownsQuery, allPropertyTypesQuery } from "@/lib/queries";

const properties = await sanityClient.fetch(allPropertiesQuery);
const towns = await sanityClient.fetch(allTownsQuery);
const propertyTypes = await sanityClient.fetch(allPropertyTypesQuery);
---

<Base title="Properties" description="Browse all properties for sale and to rent.">
  <div class="container py-8 md:py-12">
    <Breadcrumbs
      items={[
        { label: "Home", href: "/" },
        { label: "Properties" },
      ]}
    />

    <h1 class="text-3xl md:text-4xl font-bold mb-8">All Properties</h1>

    <PropertyFilter
      client:load
      properties={properties}
      towns={towns}
      propertyTypes={propertyTypes}
    />
  </div>
</Base>
