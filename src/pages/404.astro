---
import Base from "@/layouts/Base.astro";
---

<Base title="Page Not Found" noindex={true}>
  <div class="container py-24 md:py-36 text-center">
    <p class="text-6xl md:text-8xl font-bold text-gray-200 mb-4">404</p>
    <h1 class="text-2xl md:text-3xl font-bold mb-3">Page Not Found</h1>
    <p class="text-gray-500 mb-8">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div class="flex justify-center gap-4">
      <a
        href="/"
        class="px-6 py-3 rounded-lg text-white font-semibold text-sm"
        style="background: var(--color-brand)"
      >
        Go Home
      </a>
      <a
        href="/properties"
        class="px-6 py-3 rounded-lg border border-gray-300 font-semibold text-sm hover:bg-gray-50 transition-colors"
      >
        Browse Properties
      </a>
    </div>
  </div>
</Base>
