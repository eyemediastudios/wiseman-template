---
import PropertyCard from "./PropertyCard.astro";

interface Props {
  properties: any[];
  columns?: 2 | 3;
}

const { properties, columns = 3 } = Astro.props;
const gridCols = columns === 2
  ? "grid-cols-1 md:grid-cols-2"
  : "grid-cols-1 md:grid-cols-2 lg:grid-cols-3";
---

{properties.length > 0 ? (
  <div class={`grid ${gridCols} gap-6`}>
    {properties.map((property) => (
      <PropertyCard property={property} />
    ))}
  </div>
) : (
  <div class="text-center py-16">
    <p class="text-gray-500 text-lg">No properties found matching your criteria.</p>
    <a href="/properties" class="inline-block mt-4 text-sm font-semibold underline" style="color: var(--color-brand)">
      View all properties
    </a>
  </div>
)}
