---
interface Props {
  siteName: string;
  tagline?: string;
}

const { siteName, tagline } = Astro.props;
---

<section class="relative overflow-hidden bg-gray-900 text-white">
  <!-- Background gradient -->
  <div class="absolute inset-0 opacity-80" style="background: linear-gradient(135deg, var(--color-brand) 0%, var(--color-brand-dark, #0f2640) 100%)"></div>

  <!-- Decorative shapes -->
  <div class="absolute top-0 right-0 w-96 h-96 rounded-full opacity-10 -translate-y-1/2 translate-x-1/3" style="background: var(--color-accent)"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full opacity-10 translate-y-1/2 -translate-x-1/4" style="background: var(--color-accent)"></div>

  <div class="container relative z-10 py-24 md:py-36 lg:py-44 text-center">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4" style="font-family: var(--font-display)">
      {tagline || `Find Your Perfect Home`}
    </h1>
    <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto mb-10">
      Browse our curated selection of properties. Expert guidance from {siteName}.
    </p>

    <!-- Quick search bar -->
    <form action="/properties" method="get" class="max-w-3xl mx-auto">
      <div class="flex flex-col sm:flex-row bg-white rounded-lg overflow-hidden shadow-2xl">
        <input
          type="text"
          name="q"
          placeholder="Search by location, postcode, or keyword..."
          class="flex-1 px-5 py-4 text-gray-800 text-base outline-none placeholder:text-gray-400"
        />
        <button
          type="submit"
          class="px-8 py-4 font-semibold text-white text-sm transition-opacity hover:opacity-90"
          style="background: var(--color-brand)"
        >
          Search
        </button>
      </div>
    </form>

    <!-- Quick links -->
    <div class="flex flex-wrap justify-center gap-4 mt-8">
      <a href="/properties?status=for-sale" class="text-sm text-white/60 hover:text-white transition-colors underline underline-offset-4">
        For Sale
      </a>
      <a href="/properties?status=for-rent" class="text-sm text-white/60 hover:text-white transition-colors underline underline-offset-4">
        To Let
      </a>
      <a href="/valuation" class="text-sm text-white/60 hover:text-white transition-colors underline underline-offset-4">
        Free Valuation
      </a>
    </div>
  </div>
</section>
