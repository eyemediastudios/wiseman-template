---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: items.map((item, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: item.label,
    ...(item.href ? { item: new URL(item.href, Astro.url.origin).href } : {}),
  })),
};
---

<nav aria-label="Breadcrumb" class="text-sm text-gray-500 mb-6">
  <ol class="flex items-center gap-2 flex-wrap">
    {items.map((item, i) => (
      <li class="flex items-center gap-2">
        {i > 0 && <span class="text-gray-300">/</span>}
        {item.href ? (
          <a href={item.href} class="hover:text-[var(--color-brand)] transition-colors">
            {item.label}
          </a>
        ) : (
          <span class="text-gray-700 font-medium">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
